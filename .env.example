# LLM provider. In development, the app auto-selects Vertex when Vertex env exists,
# otherwise OpenAI. Production requires an explicit LLM_PROVIDER.
LLM_PROVIDER=
LLM_MODEL=

# OpenAI local fallback (also used by the OCR LLM enrichment below)
OPENAI_API_KEY=

# OCR LLM enrichment. The repo ships with a populated `.cache/ocr-llm-facts.json`
# keyed by sha256(chunk_text). With this default ON, every chunk is a cache hit
# on the assessment Mongo dataset, so ingest costs $0 and finishes in ~5 minutes.
# Set this to `false` if you want a regex-only graph (no OpenAI calls at all
# during ingest). Bump OCR_LLM_EXTRACTOR_VERSION to invalidate the cache and
# re-run extraction (which will hit OpenAI).
ENABLE_LLM_OCR_FACTS=true
OPENAI_MODEL=gpt-4.1-mini
OCR_LLM_EXTRACTOR_VERSION=openai-ocr-v1

# Throughput tuning for the LLM OCR pass. Defaults are 5 chunks per OpenAI call
# and 8 in-flight calls (~40 chunks/sec on tier-2 OpenAI). Bump if your account
# has higher rate limits, lower if you hit 429s.
OCR_LLM_BATCH_SIZE=5
OCR_LLM_CONCURRENCY=8

# Cost-estimate overrides (USD per 1M tokens). Leave unset to use the built-in
# table for known models.
# OCR_LLM_PRICE_INPUT_PER_MTOK=
# OCR_LLM_PRICE_OUTPUT_PER_MTOK=

# Vertex
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=

# Mongo source data
MONGODB_URI=

# Optional semantic similarity. Falls back to signal-only similarity when disabled
# or when Vertex embeddings are unavailable.
SEMANTIC_SIMILARITY_ENABLED=false

# Optional LLM-backed golden eval execution. Without this flag, eval definitions are
# schema-checked but not run against the model/database.
RUN_LLM_EVALS=false

# Optional local chat history JSON database. Defaults to
# .cache/conversation-history.json and keeps the last N messages (default 20). Raise the
# env value for longer chats; hard cap is 2000 messages per file.
CONVERSATION_HISTORY_PATH=
CONVERSATION_HISTORY_MAX_MESSAGES=20

# Langfuse : optional prompt/tracing override. Local fallback prompts are checked in.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PROMPT_LABEL=production

NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# SKIP_LLM_HEALTH_CHECK=true
# SKIP_NEO4J_HEALTH_CHECK=true
