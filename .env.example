# LLM provider. In development, the app auto-selects Vertex when Vertex env exists,
# otherwise OpenAI. Production requires an explicit LLM_PROVIDER.
LLM_PROVIDER=
LLM_MODEL=

# OpenAI local fallback
OPENAI_API_KEY=

# Vertex
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=

# Mongo source data
MONGODB_URI=

# Optional semantic similarity. Falls back to signal-only similarity when disabled
# or when Vertex embeddings are unavailable.
SEMANTIC_SIMILARITY_ENABLED=false

# Optional LLM-backed golden eval execution. Without this flag, eval definitions are
# schema-checked but not run against the model/database.
RUN_LLM_EVALS=false

# Optional local chat history JSON database. Defaults to
# .cache/conversation-history.json and keeps the latest 40 messages.
CONVERSATION_HISTORY_PATH=
CONVERSATION_HISTORY_MAX_MESSAGES=40

# Langfuse : optional prompt/tracing override. Local fallback prompts are checked in.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PROMPT_LABEL=production

NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# SKIP_LLM_HEALTH_CHECK=true
# SKIP_NEO4J_HEALTH_CHECK=true
